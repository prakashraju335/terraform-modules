# terraform.tfvars
# Variable overrides for your Terraform deployment
# Uncomment and modify as needed

aws_region = "us-east-1"
environment = "dev"

# EC2 Configuration
ec2_instance_name      = "my-web-server"
ec2_instance_type      = "t2.micro"
ec2_availability_zone  = "us-east-1a"

# S3 Configuration (REQUIRED - provide your unique bucket name)
s3_bucket_name         = "my-unique-bucket-name-12345"
s3_versioning_enabled  = false
s3_acl                 = "private"

# Common Tags
common_tags = {
  Project     = "TerraformModules"
  ManagedBy   = "Terraform"
  Environment = "dev"
}
